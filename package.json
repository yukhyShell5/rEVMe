{
  "name": "revme",
  "private": true,
  "version": "1.0.0",
  "description": "rEVMe Smart Contract Analyzer",
  "author": "Antigravity",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
